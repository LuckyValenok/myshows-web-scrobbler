{
  "manifest_version": 3,
  "name": "MyShows Web Scrobbler",
  "description": "Автоматически отмечает просмотренные серии и фильмы на MyShows.me при просмотре на HDRezka и других веб-плеерах",
  "version": "0.2.0",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "MyShows Web Scrobbler"
  },
  "options_ui": {
    "page": "src/options/options.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "https://myshows.me/*",
    "https://*.myshows.me/*",
    "https://api.myshows.me/*"
  ],
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["src/content/index.ts"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ]
}
