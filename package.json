{
  "name": "myshows-web-scrobbler",
  "version": "0.1.0",
  "private": true,
  "description": "Browser extension to scrobble web players to MyShows.me",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc --noEmit && vite build",
    "check": "tsc --noEmit",
    "package": "npm run build && node scripts/package.mjs"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.31",
    "@types/chrome": "^0.0.287",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
